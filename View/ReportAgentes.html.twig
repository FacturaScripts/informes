    <div class="container-fluid">
        <div class="row mt-3 mb-4">
            <div class="col-12 text-center">
                <h1 class="h3 mb-0 text-gray-800">
                    <i class="fa-solid fa-user-tie"></i>
                    {{ trans('agents-report') }}
