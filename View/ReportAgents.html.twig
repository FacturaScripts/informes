{% extends "Master/MenuBgTemplate.html.twig" %}
{% import "Macro/Forms.html.twig" as forms %}

{% block body %}
    <script src="{{ asset('Plugins/Informes/node_modules/apexcharts/dist/apexcharts.min.js') }}"></script>
    <div class="container-fluid">
        <div class="d-flex flex-wrap align-items-center gap-3 mt-3 mb-3">
            <h1 class="h3 mb-0 text-gray-800 me-2">
                <i class="fa-solid fa-user-tie"></i>
                {{ trans('agents-report') }}
            </h1>
            <ul class="nav nav-pills" id="agentsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-invoices-btn" data-bs-toggle="pill"
                            data-bs-target="#tab-invoices" type="button" role="tab">
                        <i class="fa-solid fa-file-invoice me-1"></i>
                        {{ trans('invoices') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-delivery-btn" data-bs-toggle="pill"
                            data-bs-target="#tab-delivery" type="button" role="tab">
                        <i class="fa-solid fa-truck me-1"></i>
                        {{ trans('delivery-notes') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-orders-btn" data-bs-toggle="pill"
                            data-bs-target="#tab-orders" type="button" role="tab">
                        <i class="fa-solid fa-cart-shopping me-1"></i>
                        {{ trans('orders') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-estimates-btn" data-bs-toggle="pill"
                            data-bs-target="#tab-estimates" type="button" role="tab">
                        <i class="fa-solid fa-file-lines me-1"></i>
                        {{ trans('estimates') }}
                    </button>
                </li>
                {% if fsc.comisionesEnabled %}
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-commissions-btn" data-bs-toggle="pill"
                                data-bs-target="#tab-commissions" type="button" role="tab">
                            <i class="fa-solid fa-hand-holding-dollar me-1"></i>
                            {{ trans('commissions') }}
                        </button>
                    </li>
                {% endif %}
            </ul>
            <form action="{{ fsc.url() }}" method="get" id="reportForm" class="mb-0 ms-auto" style="min-width: 260px;">
                {{ forms.simpleSelect('selectEmpresa', 'idempresa', fsc.idempresa, fsc.companies, null, 'fa-solid fa-building') }}
            </form>
        </div>

        <div class="tab-content" id="agentsTabsContent">
            {# === FACTURAS === #}
            <div class="tab-pane fade show active" id="tab-invoices" role="tabpanel">
                <div class="row">
                    <div class="col-xl-4 col-lg-5 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-file-invoice me-1"></i>
                                    {{ trans('invoices-by-agent') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.facturas.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-8 col-lg-7 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-chart-bar me-1"></i>
                                    {{ trans('invoices-by-month') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.facturasByMonth.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-column me-1"></i>
                            {{ trans('invoices-by-year') }}
                        </h6>
                    </div>
                    <div class="card-body">
                        {{ fsc.facturasByYear.getChart().render({'height': 350}) | raw }}
                    </div>
                </div>
            </div>

            {# === ALBARANES === #}
            <div class="tab-pane fade" id="tab-delivery" role="tabpanel">
                <div class="row">
                    <div class="col-xl-4 col-lg-5 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-truck me-1"></i>
                                    {{ trans('delivery-notes-by-agent') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.albaranes.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-8 col-lg-7 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-chart-bar me-1"></i>
                                    {{ trans('delivery-notes-by-month') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.albaranesByMonth.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-column me-1"></i>
                            {{ trans('delivery-notes-by-year') }}
                        </h6>
                    </div>
                    <div class="card-body">
                        {{ fsc.albaranesByYear.getChart().render({'height': 350}) | raw }}
                    </div>
                </div>
            </div>

            {# === PEDIDOS === #}
            <div class="tab-pane fade" id="tab-orders" role="tabpanel">
                <div class="row">
                    <div class="col-xl-4 col-lg-5 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-cart-shopping me-1"></i>
                                    {{ trans('orders-by-agent') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.pedidos.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-8 col-lg-7 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-chart-bar me-1"></i>
                                    {{ trans('orders-by-month') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.pedidosByMonth.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-column me-1"></i>
                            {{ trans('orders-by-year') }}
                        </h6>
                    </div>
                    <div class="card-body">
                        {{ fsc.pedidosByYear.getChart().render({'height': 350}) | raw }}
                    </div>
                </div>
            </div>

            {# === PRESUPUESTOS === #}
            <div class="tab-pane fade" id="tab-estimates" role="tabpanel">
                <div class="row">
                    <div class="col-xl-4 col-lg-5 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-file-lines me-1"></i>
                                    {{ trans('estimates-by-agent') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.presupuestos.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-8 col-lg-7 mb-4 d-flex">
                        <div class="card shadow w-100">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fa-solid fa-chart-bar me-1"></i>
                                    {{ trans('estimates-by-month') }}
                                </h6>
                            </div>
                            <div class="card-body">
                                {{ fsc.presupuestosByMonth.getChart().render({'height': 260}) | raw }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fa-solid fa-chart-column me-1"></i>
                            {{ trans('estimates-by-year') }}
                        </h6>
                    </div>
                    <div class="card-body">
                        {{ fsc.presupuestosByYear.getChart().render({'height': 350}) | raw }}
                    </div>
                </div>
            </div>

            {# === COMISIONES + LIQUIDACIONES === #}
            {% if fsc.comisionesEnabled %}
                <div class="tab-pane fade" id="tab-commissions" role="tabpanel">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h6 class="m-0 font-weight-bold text-success">
                                        <i class="fa-solid fa-hand-holding-dollar me-1"></i>
                                        {{ trans('commissions-by-month') }}
                                    </h6>
                                </div>
                                <div class="card-body">
                                    {{ fsc.comisionesByMonth.getChart().render({'height': 260}) | raw }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h6 class="m-0 font-weight-bold text-success">
                                        <i class="fa-solid fa-chart-column me-1"></i>
                                        {{ trans('commissions-by-year') }}
                                    </h6>
                                </div>
                                <div class="card-body">
                                    {{ fsc.comisionesByYear.getChart().render({'height': 350}) | raw }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h6 class="m-0 font-weight-bold text-info">
                                        <i class="fa-solid fa-money-bill-transfer me-1"></i>
                                        {{ trans('settlements-by-month') }}
                                    </h6>
                                </div>
                                <div class="card-body">
                                    {{ fsc.liquidacionesByMonth.getChart().render({'height': 260}) | raw }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h6 class="m-0 font-weight-bold text-info">
                                        <i class="fa-solid fa-chart-column me-1"></i>
                                        {{ trans('settlements-by-year') }}
                                    </h6>
                                </div>
                                <div class="card-body">
                                    {{ fsc.liquidacionesByYear.getChart().render({'height': 350}) | raw }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            $('#selectEmpresa').val('{{ fsc.idempresa }}');
            $('#selectEmpresa').on('change', function () {
                $('#reportForm').submit();
            });
        });
    </script>
{% endblock %}
