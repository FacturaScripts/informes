{#
Vista hecha para Controller/ListReport.php

Se trata de un asistente que te hace elegir tabla y luego su respectiva fila

Se podría refactorizar o hacer el componente más reutilizable si se pasan como argumentos las traducciones, títulos, acción destino, etc

#}
{% extends "Master/MenuTemplate.html.twig" %}
{% import "Macro/Forms.html.twig" as forms %}

{% block body %}
    {{ parent() }}

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="fa-solid fa-hat-wizard me-1"></i>
                            {{ trans('wizard') }} {{ trans('reports-board')|lower }}
                        </h4>
                    </div>

                    {% if fsc.twigData.selectedTable %}
                        {# STEP 2 #}
                        <div class="card-body">
                            <h5 class="card-title">{{ trans('column') }}</h5>
                            <p class="card-text text-muted">
                                {{ trans('report-board-wizard-column-help', {'%table%': fsc.twigData.selectedTable}) }}
                            </p>

                            <form action="{{ fsc.url() }}" method="post">
                                {{ formToken() }}
                                <input type="hidden" name="action" value="process-custom-board">
                                <input type="hidden" name="selectedTable" value="{{ fsc.twigData.selectedTable }}">

                                <div class="mb-3">
                                    {{ forms.simpleSelect('selectColumna', 'selectedColumn', null, fsc.twigData.columns, trans('column'), 'fa-solid fa-columns') }}
                                </div>

                                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                    <a href="{{ fsc.url() }}?action=custom-board-assistant" class="btn btn-outline-secondary me-md-2">
                                        <i class="fa-solid fa-arrow-left"></i> {{ trans('back') }}
                                    </a>
                                    <button class="btn btn-primary" type="submit">
                                        {{ trans('create') }} <i class="fa-solid fa-check"></i>
                                    </button>
                                </div>
                            </form>
                        </div>
                    {% else %}
                        {# STEP 1 #}
                        <div class="card-body">
                            <div class="border rounded p-3 mb-4">
                                <h5 class="card-title">{{ trans('generate') }} {{ trans('default')|lower }}</h5>
                                <p class="card-text text-muted">{{ trans('report-board-wizard-default-help') }}</p>

                                <form action="{{ fsc.url() }}" method="post">
                                    {{ formToken() }}
                                    <input type="hidden" name="action" value="generate-boards">

                                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                        <button class="btn btn-primary" type="submit">
                                            <i class="fa-solid fa-wand-magic-sparkles me-1"></i>{{ trans('generate') }}
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <div class="border rounded p-3">
                                <h5 class="card-title">{{ trans('create') }} {{ trans('reports-board')|lower }} {{ trans('date')|lower }}</h5>
                                <p class="card-text text-muted">{{ trans('report-board-wizard-date-help') }}</p>

                                <form action="{{ fsc.url() }}" method="get" id="reportForm">
                                    <input type="hidden" name="action" value="custom-board-assistant">

                                    <div class="mb-3">
                                        {{ forms.simpleSelect('selectTabla', 'selectedTable', fsc.twigData.selectedTable, fsc.twigData.tables, trans('table'), 'fa-solid fa-table') }}
                                    </div>

                                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                        <button class="btn btn-outline-primary" type="submit">
                                            {{ trans('next') }} <i class="fa-solid fa-arrow-right"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
