{% set reportsBoardsUser = fsc.getReportsBoardsUser() %}
{% if reportsBoardsUser is not empty() %}
    <div class="card shadow mb-3">
        <div class="p-3">
            <h2 class="h4 mb-0">
                <i class="fa-solid fa-chalkboard fa-fw"></i>
                {{ trans('reports-board') }}
            </h2>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <tbody>
                {% for reportBoardUser in reportsBoardsUser %}
                    <tr class="clickableRow" data-href="{{ reportBoardUser.url() }}">
                        <td>{{ reportBoardUser.getReportBoard().name }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}